{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "mcp__[A-Za-z0-9_-]*[Ll]inear[A-Za-z0-9_-]*__(create_comment|save_comment)|save_comment|create_comment",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/validate_tracking_json.py"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/validate_workflow_on_prompt.py"
          }
        ]
      }
    ]
  }
}
